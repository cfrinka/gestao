# Environment for the public portfolio demo deployment.
#
# This build never touches Firebase — leave every NEXT_PUBLIC_FIREBASE_*/FIREBASE_* variable
# from .env.example unset here. That's intentional: it's the easiest way to confirm demo mode
# never falls through to the real Firestore/Auth code paths (any missed call site fails loudly
# with a 500 instead of silently touching production data).
#
# Requires a persistent Node process (e.g. `npm run build:demo && npm run start:demo` on
# Railway/Render/Fly.io or similar) — NOT typical serverless hosting. Demo sessions are kept
# in an in-memory Map keyed by a signed cookie, which only works if requests keep landing on
# the same long-running process.

# Enables demo mode server-side (auth stub, in-memory repositories, disabled admin/image routes).
DEMO_MODE=true

# Enables demo mode in the client bundle. Next.js inlines NEXT_PUBLIC_* at BUILD time, not start
# time — make sure this is set when running `next build` / `npm run build:demo`, not only at
# `next start`.
NEXT_PUBLIC_DEMO_MODE=true

# HMAC key signing the demo_session cookie. Not protecting real data (the whole point of this
# deployment is that there's none to protect) — just prevents a visitor from trivially editing
# the cookie to claim the Admin role. Set to any random string.
DEMO_SESSION_SECRET=change-me-to-a-random-string
